{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && ./mvnw clean package -DskipTests"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd server && java -jar target/*.jar",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE"
  }
}